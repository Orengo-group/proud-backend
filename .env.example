# ─── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ────────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/proud_db

# ─── Authentication ──────────────────────────────────────────────────────────────
# Must be at least 32 characters long
JWT_SECRET=change_me_to_a_long_random_secret_of_at_least_32_chars
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────────
# Use a specific origin in production, e.g. https://app.proud.io
CORS_ORIGIN=*
